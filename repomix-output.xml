                      <td style={{ ...s.td, color: '#4ADE80' }}>{fmt(row.principal)}</td>
                      <td style={{ ...s.td, color: '#F87171' }}>{fmt(row.interest)}</td>
                      <td style={s.td}>{fmt(row.balance)}</td>
                      <td style={{ ...s.td, color: '#D4AF37' }}>{row.equity.toFixed(1)}%</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </>
      )}
    </div>
  );
}
