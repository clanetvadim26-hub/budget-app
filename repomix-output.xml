                <div className={`upcoming-date ${isOverdue ? 'negative' : ''}`}>
                  {item.isPaid
                    ? '✓ Paid'
                    : item.daysUntil === 0
                    ? 'Due today'
                    : item.daysUntil < 0
                    ? `${Math.abs(item.daysUntil)}d overdue`
                    : `${format(item.date, 'MMM d')}`}
