}
.pc-tip-icon  { font-size: 18px; }
.pc-tip-label { font-size: 12px; color: #94A3B8; font-weight: 600; }
.pc-tip-pct   { font-size: 11px; color: #475569; }
.pc-tip-val   { font-size: 15px; font-weight: 700; color: #F472B6; font-variant-numeric: tabular-nums; }

.pc-jessica-placeholder {
