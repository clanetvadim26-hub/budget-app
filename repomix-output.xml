    >
      <option value="">🔗 link</option>
      {groups.map(g => {
        const accs = (accounts || []).filter(a => g.types.includes(a.type));
        if (!accs.length) return null;
        return (
          <optgroup key={g.label} label={g.label}>
            {accs.map(a => <option key={a.id} value={a.id}>{a.name}</option>)}
          </optgroup>
        );
      })}
