.roth-phaseout-icon { color: #38BDF8; font-size: 14px; flex-shrink: 0; }

.tracker-card-clickable { cursor: pointer; }
.tracker-card-clickable:hover { border-color: rgba(255,255,255,0.15); }
.tracker-details-hint {
  font-size: 11px;
  color: #64748B;
  margin-left: auto;
  transition: color 0.2s;
}
.tracker-card-clickable:hover .tracker-details-hint { color: #D4AF37; }

