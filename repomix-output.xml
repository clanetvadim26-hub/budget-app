  border-bottom: 1px solid #0F172A;
}

.transaction-row:last-child { border-bottom: none; }

.txn-icon { font-size: 18px; flex-shrink: 0; }

.txn-desc { flex: 1; }

.txn-category {
  font-size: 13px;
  font-weight: 600;
  color: #E2E8F0;
}

.txn-note {
  font-size: 12px;
  color: #64748B;
  margin-top: 1px;
}

.txn-date {
  font-size: 12px;
  color: #475569;
  white-space: nowrap;
}

.txn-amount {
  font-size: 14px;
  font-weight: 700;
  color: #F87171;
  white-space: nowrap;
}

/* ========================
   ADVICE PANEL
   ======================== */
.advice-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin-bottom: 28px;
}

.advice-card {
