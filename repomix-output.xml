.pc-placeholder-sub  { font-size: 12px; color: #334155; }

/* ── Sync Retry Button ───────────────────────────────── */
.sync-retry-btn {
  background: #D4AF37;
  color: #0A0F1E;
  border: none;
  border-radius: 6px;
  padding: 2px 10px;
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  margin-left: 10px;
  transition: opacity 0.15s;
}
.sync-retry-btn:hover { opacity: 0.85; }

/* ── Setup Wizard ────────────────────────────────────── */
.wizard-overlay {
  position: fixed;
  inset: 0;
  background: rgba(5, 8, 22, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  padding: 16px;
}
.wizard-card {
  background: #0D1426;
  border: 1px solid #1E293B;
  border-radius: 20px;
  max-width: 600px;
  width: 100%;
  max-height: 90vh;
  overflow-y: auto;
  padding: 32px;
}
.wizard-steps {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32px;
}
.wizard-dot {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: #1E293B;
  color: #64748B;
  font-size: 13px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: 0.15s;
  flex-shrink: 0;
}
.wizard-dot.active { background: #D4AF37; color: #0A0F1E; }
.wizard-dot.done   { background: #4ADE80; color: #0A0F1E; }
.wizard-dot-label {
  position: absolute;
  top: 38px;
  font-size: 10px;
  color: #64748B;
  white-space: nowrap;
}
.wizard-connector { height: 2px; width: 60px; background: #1E293B; margin: 0 4px; transition: 0.15s; }
.wizard-connector.done { background: #4ADE80; }
.wizard-body { display: flex; flex-direction: column; align-items: center; gap: 16px; }
.wizard-icon { font-size: 48px; }
.wizard-title { font-size: 22px; font-weight: 700; color: #F1F5F9; text-align: center; margin: 0; }
.wizard-desc  { font-size: 14px; color: #94A3B8; text-align: center; max-width: 420px; line-height: 1.5; margin: 0; }
.wizard-btn-primary {
  background: linear-gradient(135deg, #D4AF37, #C9A227);
  color: #0A0F1E;
  border: none;
  border-radius: 10px;
  padding: 12px 28px;
  font-size: 15px;
  font-weight: 700;
  cursor: pointer;
  width: 100%;
  max-width: 320px;
  min-height: 44px;
  transition: opacity 0.15s;
}
.wizard-btn-primary:hover { opacity: 0.88; }
.wizard-btn-secondary {
  background: transparent;
  color: #94A3B8;
  border: 1px solid #334155;
  border-radius: 10px;
  padding: 10px 20px;
  font-size: 14px;
  cursor: pointer;
  min-height: 44px;
  transition: 0.15s;
}
.wizard-btn-secondary:hover { border-color: #D4AF37; color: #D4AF37; }
.wizard-btn-skip { background: none; border: none; color: #475569; font-size: 13px; cursor: pointer; }
.wizard-accounts-list { width: 100%; display: flex; flex-direction: column; gap: 12px; max-height: 50vh; overflow-y: auto; }
.wizard-account-row { background: #131d35; border: 1px solid #1E293B; border-radius: 12px; padding: 12px; }
.wizard-account-name { font-size: 14px; font-weight: 600; color: #F1F5F9; margin-bottom: 8px; }
.wizard-account-owner { color: #64748B; font-weight: 400; }
.wizard-account-fields { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 8px; }
.wizard-field label { display: block; font-size: 11px; color: #64748B; margin-bottom: 3px; text-transform: uppercase; letter-spacing: 0.5px; }
.wizard-input { width: 100%; background: #0A1020; border: 1px solid #1E293B; border-radius: 8px; color: #F1F5F9; font-size: 16px; padding: 8px 10px; box-sizing: border-box; }
.wizard-input:focus { outline: none; border-color: #D4AF37; }
.wizard-footer { display: flex; gap: 12px; width: 100%; justify-content: space-between; margin-top: 8px; }
.wizard-summary { width: 100%; display: flex; flex-direction: column; gap: 8px; }
.wizard-summary-row { display: flex; justify-content: space-between; padding: 8px 12px; background: #131d35; border-radius: 8px; font-size: 14px; color: #CBD5E1; }
.wizard-summary-amount { color: #4ADE80; font-weight: 600; }

/* ── Overview Budget Summary ─────────────────────────── */
.obs-panel .panel-header { margin-bottom: 16px; }
.obs-edit-btn { background: transparent; border: 1px solid #D4AF37; color: #D4AF37; border-radius: 8px; padding: 6px 14px; font-size: 13px; cursor: pointer; transition: 0.15s; }
.obs-edit-btn:hover { background: rgba(212,175,55,0.1); }
.obs-empty { text-align: center; padding: 20px; color: #64748B; display: flex; flex-direction: column; align-items: center; gap: 12px; }
.obs-setup-btn { background: linear-gradient(135deg, #D4AF37, #C9A227); color: #0A0F1E; border: none; border-radius: 8px; padding: 8px 20px; font-size: 14px; font-weight: 600; cursor: pointer; }
.obs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
@media (max-width: 600px) { .obs-grid { grid-template-columns: 1fr; } }
.obs-person-card { background: #131d35; border: 1px solid #1E293B; border-radius: 12px; padding: 14px; }
.vadim-card   { border-left: 3px solid #60A5FA; }
.jessica-card { border-left: 3px solid #F472B6; }
.obs-person-header { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
.obs-person-icon { font-size: 20px; }
.obs-person-name { font-size: 14px; font-weight: 700; color: #F1F5F9; flex: 1; }
.obs-person-income { font-size: 15px; font-weight: 700; color: #4ADE80; }
.obs-bar { height: 10px; border-radius: 5px; background: #0A1020; display: flex; overflow: hidden; margin-bottom: 10px; }
.obs-bar-seg { height: 100%; transition: width 0.3s; }
.obs-fixed { background: #F87171; }
.obs-variable { background: #FBBF24; }
.obs-savings { background: #D4AF37; }
.obs-disc { background: #4ADE80; }
.obs-legend { display: flex; flex-wrap: wrap; gap: 8px; }
.obs-legend-item { font-size: 11px; color: #94A3B8; display: flex; align-items: center; gap: 4px; }
.obs-fixed-dot::before, .obs-variable-dot::before, .obs-savings-dot::before, .obs-disc-dot::before { content: ''; display: inline-block; width: 8px; height: 8px; border-radius: 50%; }
.obs-fixed-dot::before    { background: #F87171; }
.obs-variable-dot::before { background: #FBBF24; }
.obs-savings-dot::before  { background: #D4AF37; }
.obs-disc-dot::before     { background: #4ADE80; }
.obs-household-row { display: flex; gap: 16px; padding-top: 12px; border-top: 1px solid #1E293B; flex-wrap: wrap; }
.obs-hh-stat { flex: 1; min-width: 100px; }
.obs-hh-label { display: block; font-size: 11px; color: #64748B; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
.obs-hh-val { font-size: 18px; font-weight: 700; }

/* ── Paycheck Defer Button ─────────────────────────────── */
.paycheck-defer-btn { background: transparent; border: 1px solid #F87171; color: #F87171; border-radius: 10px; padding: 10px 16px; font-size: 13px; cursor: pointer; width: 100%; min-height: 44px; transition: 0.15s; margin-top: 4px; }
.paycheck-defer-btn:hover { background: rgba(248,113,113,0.1); }

/* ── Paycheck History Panel ────────────────────────────── */
.paycheck-history-panel { padding: 0 4px; }
.ph-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; flex-wrap: wrap; gap: 8px; }
.ph-title  { font-size: 18px; font-weight: 700; color: #F1F5F9; margin: 0; }
.ph-subtotals { display: flex; gap: 16px; }
.ph-subtotal  { font-size: 14px; font-weight: 600; }
.vadim-color   { color: #60A5FA; }
.jessica-color { color: #F472B6; }
.ph-table-wrap { overflow-x: auto; }
.ph-table { width: 100%; border-collapse: collapse; font-size: 13px; }
