}
.roth-bar-status { font-size: 12px; font-weight: 600; }
.roth-bar-amounts { font-size: 14px; margin-bottom: 6px; }
.roth-bar-footer {
  display: flex;
  justify-content: space-between;
  font-size: 12px;
