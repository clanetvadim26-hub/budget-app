.pc-jessica-alloc-left { display: flex; flex-direction: column; gap: 3px; flex: 1; }
.pc-jessica-alloc-label { font-size: 14px; font-weight: 700; }
.pc-jessica-alloc-pct {
  font-size: 11px;
  color: #64748B;
  font-weight: 600;
  text-transform: uppercase;
