  color: #475569;
  font-size: 14px;
}

.category-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 4px 10px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 500;
  white-space: nowrap;
}

/* ========================
   RESPONSIVE
   ======================== */
@media (max-width: 1024px) {
  .charts-row { grid-template-columns: 1fr; }
  .form-panel { grid-template-columns: 1fr; }
  .savings-goals { grid-template-columns: 1fr; }
}

@media (max-width: 768px) {
  .navbar {
    width: 100%;
    height: auto;
    position: fixed;
    top: 0;
    flex-direction: row;
    overflow-x: auto;
    overflow-y: hidden;
    padding: 0 12px;
    border-right: none;
    border-bottom: 1px solid #1E293B;
    z-index: 200;
    align-items: center;
  }

  .navbar-brand { border-bottom: none; padding: 12px 12px 12px 0; flex-shrink: 0; }
  .brand-sub { display: none; }
  .nav-links { flex-direction: row; padding: 8px 0; gap: 4px; }
  .nav-item { padding: 8px 10px; border-radius: 8px; white-space: nowrap; }
  .nav-label { display: none; }
  .view-toggle { border-top: none; border-left: 1px solid #1E293B; padding: 8px 12px; flex-shrink: 0; }
  .toggle-btn { padding: 6px 8px; font-size: 11px; }

  .main-content {
    margin-left: 0;
    margin-top: 60px;
    padding: 16px;
  }

  .stats-grid { grid-template-columns: 1fr 1fr; }
  .stat-amount { font-size: 22px; }
  .cashflow-summary { grid-template-columns: 1fr; }
  .form-panel { grid-template-columns: 1fr; }
  .form-row { grid-template-columns: 1fr; }
  .goal-inputs { grid-template-columns: 1fr; }
  .alloc-label { width: 130px; font-size: 12px; }

  .table-header, .table-row { grid-template-columns: 2fr 1fr; }
  .table-pct { display: none; }

  .cashflow-table .table-header,
  .cashflow-table .table-row { grid-template-columns: 1fr 1fr 1fr 1fr; }
}

@media (max-width: 480px) {
  .stats-grid { grid-template-columns: 1fr; }
  .panel { padding: 16px; }
}

