.vbill-modal   { max-width: 420px; }

.jessica-amount-wrap {
  display: flex;
  align-items: center;
  background: #0A1020;
  border: 2px solid #1E2D45;
  border-radius: 12px;
  padding: 10px 16px;
  margin-bottom: 20px;
  gap: 4px;
}
.jessica-amount-wrap:focus-within { border-color: #D4AF37; }
.jessica-dollar { font-size: 20px; color: #D4AF37; font-weight: 700; }
.jessica-amount-input {
  flex: 1;
  background: transparent;
  border: none;
  color: #F1F5F9;
  font-size: 24px;
  font-weight: 700;
  outline: none;
}

/* Variable bill modal */
.vbill-body { padding: 16px 20px; }
.vbill-prompt { font-size: 15px; color: #CBD5E1; margin-bottom: 16px; text-align: center; }
.vbill-history {
  background: #060E1A;
  border: 1px solid #1E2D45;
  border-radius: 8px;
  padding: 10px 14px;
  margin-bottom: 16px;
}
.vbill-history-title {
  font-size: 11px;
  color: #64748B;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 6px;
}
.vbill-history-row {
  display: flex;
  justify-content: space-between;
  font-size: 13px;
  color: #94A3B8;
  padding: 3px 0;
}
.vbill-avg-row { color: #CBD5E1; font-weight: 600; border-top: 1px solid #1E2D45; margin-top: 4px; padding-top: 6px; }
.vbill-avg-hint { font-size: 12px; color: #64748B; text-align: center; margin-bottom: 14px; }
.vbill-amount-wrap { margin-bottom: 12px; }

/* ═══════════════════════════════════════════════════════════════════════
   FINANCIAL ALERTS PANEL
   ═══════════════════════════════════════════════════════════════════════ */
.fa-panel {}
.fa-list { display: flex; flex-direction: column; gap: 8px; }
.fa-alert {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  background: #0A1020;
  border: 1px solid #1E2D45;
  border-left: 4px solid #D4AF37;
  border-radius: 8px;
  padding: 10px 14px;
  font-size: 13px;
  color: #CBD5E1;
  transition: background 0.2s;
}
.fa-alert.fa-urgent {
  background: rgba(248, 113, 113, 0.05);
}
.fa-icon { font-size: 16px; flex-shrink: 0; margin-top: 1px; }
.fa-text { flex: 1; line-height: 1.5; }

/* ═══════════════════════════════════════════════════════════════════════
   BUDGET PLAN PANEL
   ═══════════════════════════════════════════════════════════════════════ */
.bp-panel {}
.bp-income-hero {
  text-align: center;
  padding: 16px 0 12px;
}
.bp-income-label {
  font-size: 12px;
  color: #64748B;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 4px;
}
.bp-income-amount {
  font-size: 36px;
  font-weight: 800;
  color: #D4AF37;
}
.bp-income-sub {
  font-size: 12px;
  color: #64748B;
  margin-top: 2px;
}

.bp-bar-wrap {
  display: flex;
  height: 12px;
  border-radius: 6px;
  overflow: hidden;
  margin: 12px 0 6px;
  gap: 2px;
}
.bp-bar-seg { height: 100%; transition: width 0.5s ease; border-radius: 2px; }
.bp-bar-legend {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
  margin-bottom: 16px;
}
.bp-legend-item {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 11px;
  color: #64748B;
}
.bp-legend-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
}

.bp-sections { display: flex; flex-direction: column; gap: 2px; }
.bp-section {
  border: 1px solid #1E2D45;
  border-radius: 8px;
  overflow: hidden;
  margin-bottom: 4px;
}
.bp-section-header {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 14px;
  cursor: pointer;
  background: #0A1020;
  user-select: none;
}
.bp-section-header:hover { background: #0D1830; }
.bp-discretionary-header { cursor: default; }
.bp-discretionary-header:hover { background: #0A1020; }
.bp-section-title {
  flex: 1;
  font-size: 14px;
  font-weight: 600;
  color: #CBD5E1;
}
.bp-section-total {
  font-size: 14px;
  font-weight: 700;
}
.bp-section-toggle { font-size: 10px; color: #64748B; }
.bp-section-body { padding: 4px 0; background: #060E1A; }

.bp-row {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 14px;
  border-bottom: 1px solid #0D1830;
  font-size: 13px;
}
.bp-row:last-child { border-bottom: none; }
.bp-row-icon { font-size: 14px; flex-shrink: 0; width: 20px; text-align: center; }
.bp-row-name { flex: 1; color: #CBD5E1; }
.bp-row-note { font-size: 11px; color: #475569; }
.bp-row-amount { font-weight: 600; }

/* ═══════════════════════════════════════════════════════════════════════
   INLINE EDIT COMPONENT
   ═══════════════════════════════════════════════════════════════════════ */
.ie-wrap {
  display: inline-flex;
  align-items: center;
  gap: 3px;
  cursor: pointer;
  border-radius: 4px;
  padding: 2px 4px;
  transition: background 0.15s;
}
.ie-display:hover { background: rgba(212,175,55,0.08); }
.ie-saved-state   { background: rgba(74,222,128,0.08); }
.ie-value  { font-weight: 600; }
.ie-hint   { font-size: 10px; color: #475569; opacity: 0; transition: opacity 0.15s; }
.ie-display:hover .ie-hint { opacity: 1; }
.ie-saved  { font-size: 11px; color: #4ADE80; font-weight: 700; }
.ie-prefix, .ie-suffix { font-size: 12px; color: #64748B; }
.ie-editing { cursor: text; }
.ie-input {
  background: #0A1020;
  border: 1px solid #D4AF37;
  border-radius: 5px;
  color: #F1F5F9;
  font-size: 14px;
  font-weight: 600;
  padding: 3px 8px;
  width: 90px;
  outline: none;
}

/* ═══════════════════════════════════════════════════════════════════════
   FULL BUDGET PLAN PANEL
   ═══════════════════════════════════════════════════════════════════════ */
.fbp-container {}
.fbp-tab-bar {
  display: flex;
  gap: 6px;
  margin-bottom: 16px;
}
.fbp-tab {
  flex: 1;
  background: #1E2D45;
  border: 1px solid #2D3F5E;
  color: #64748B;
  border-radius: 8px;
  padding: 10px;
  font-size: 14px;
  cursor: pointer;
  transition: background 0.2s, color 0.2s;
}
.fbp-tab:hover  { background: #253550; color: #CBD5E1; }
.fbp-tab.active { background: #D4AF37; color: #0A0F1E; border-color: #D4AF37; font-weight: 700; }

.fbp-view { display: flex; flex-direction: column; gap: 12px; }
.fbp-section {
  background: #0A1020;
  border: 1px solid #1E2D45;
  border-radius: 10px;
  overflow: hidden;
}
.fbp-section-header {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px 14px;
  background: #0D1830;
  border-bottom: 1px solid #1E2D45;
}
.fbp-section-icon  { font-size: 16px; }
.fbp-section-title { flex: 1; font-size: 14px; font-weight: 700; color: #CBD5E1; }
.fbp-section-total { font-size: 14px; font-weight: 700; }

.fbp-table { width: 100%; }
.fbp-table-head {
  display: flex;
  gap: 10px;
  padding: 7px 14px;
  font-size: 11px;
  color: #475569;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  border-bottom: 1px solid #111A2E;
}
.fbp-table-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 9px 14px;
  border-bottom: 1px solid #0D1830;
  font-size: 13px;
  color: #CBD5E1;
}
.fbp-table-row:last-child { border-bottom: none; }
.fbp-table-row > span:first-child { flex: 1; }

.fbp-expenses-table .fbp-table-head,
.fbp-expenses-table .fbp-table-row {
  display: grid;
  grid-template-columns: 1fr auto 60px 28px;
  align-items: center;
}
.fbp-col-due { font-size: 12px; color: #64748B; text-align: right; }

/* Delete button on expense rows */
.fbp-delete-btn {
  background: none;
  border: none;
  color: #475569;
  font-size: 16px;
  line-height: 1;
  cursor: pointer;
  padding: 0 4px;
  opacity: 0;
  transition: opacity 0.15s, color 0.15s;
}
.fbp-expenses-table .fbp-table-row:hover .fbp-delete-btn { opacity: 1; }
.fbp-delete-btn:hover { color: #F87171; }

/* Add expense row */
.fbp-add-row {
  display: flex;
  gap: 6px;
  padding: 8px 14px;
  border-top: 1px dashed #1E293B;
  align-items: center;
  flex-wrap: wrap;
}
.fbp-add-input {
  background: #0F172A;
  border: 1px solid #334155;
  border-radius: 6px;
  color: #F1F5F9;
  font-size: 13px;
  padding: 5px 8px;
  outline: none;
}
.fbp-add-input:focus { border-color: #3B82F6; }
.fbp-add-name   { flex: 1; min-width: 120px; }
.fbp-add-amount { width: 80px; }
.fbp-add-due    { width: 60px; }
.fbp-add-confirm {
  background: #22C55E22;
  border: 1px solid #22C55E;
  border-radius: 6px;
  color: #22C55E;
  font-size: 12px;
  padding: 5px 10px;
  cursor: pointer;
}
.fbp-add-cancel {
  background: none;
  border: 1px solid #334155;
  border-radius: 6px;
  color: #64748B;
  font-size: 12px;
  padding: 5px 10px;
  cursor: pointer;
}
.fbp-add-btn {
  background: none;
  border: 1px dashed #334155;
  border-radius: 6px;
  color: #64748B;
  font-size: 12px;
  padding: 6px 14px;
  cursor: pointer;
  margin: 8px 14px;
  width: calc(100% - 28px);
  text-align: left;
  transition: border-color 0.15s, color 0.15s;
}
.fbp-add-btn:hover { border-color: #4ADE80; color: #4ADE80; }

.fbp-ie-name .ie-value { font-weight: 500; }

.fbp-savings-head,
.fbp-savings-row {
  display: grid !important;
  grid-template-columns: 1fr auto auto;
}
.fbp-savings-name {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.fbp-projected { font-size: 11px; color: #64748B; }

.fbp-alloc-head,
.fbp-alloc-table .fbp-table-row {
  display: grid !important;
  grid-template-columns: 1fr 80px auto;
}

.fbp-row-name  { flex: 1; display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
.fbp-row-label { flex: 1; color: #CBD5E1; }
.fbp-subdued   { color: #475569; font-size: 12px; }
.fbp-bold      { font-weight: 700; }
.fbp-total-row { background: #060E1A; font-weight: 600; }
.fbp-future    { opacity: 0.65; }
.fbp-warning {
  background: rgba(251,191,36,0.08);
  border: 1px solid #FBBF24;
  color: #FBBF24;
  font-size: 12px;
  padding: 8px 14px;
  border-radius: 6px;
  margin: 8px 14px;
}

.fbp-chip {
  display: inline-block;
  border-radius: 8px;
  padding: 1px 7px;
  font-size: 10px;
  font-weight: 600;
}
.fbp-chip.red    { background: rgba(248,113,113,0.15); color: #F87171; }
.fbp-chip.yellow { background: rgba(251,191,36,0.15);  color: #FBBF24; }
.fbp-chip.blue   { background: rgba(56,189,248,0.15);  color: #38BDF8; }
.fbp-chip.purple { background: rgba(167,139,250,0.15); color: #A78BFA; }

.fbp-ie { font-size: 13px; }

.fbp-rate-wrap { display: flex; align-items: center; gap: 8px; }
.fbp-rate-bar-track {
  flex: 1;
  height: 6px;
  background: #1E2D45;
  border-radius: 3px;
  overflow: hidden;
  min-width: 80px;
}
.fbp-rate-bar-fill { height: 100%; border-radius: 3px; transition: width 0.4s ease; }

/* Budget plan summary block */
.fbp-summary {
  background: #060E1A;
  border: 1px solid #1E2D45;
  border-radius: 10px;
  padding: 14px;
}
.fbp-summary-title {
  font-size: 13px;
  font-weight: 700;
  color: #94A3B8;
  margin-bottom: 10px;
}
.fbp-summary-grid { display: flex; flex-direction: column; gap: 6px; margin-bottom: 12px; }
.fbp-summary-row {
  display: flex;
  justify-content: space-between;
  font-size: 13px;
  color: #94A3B8;
  padding: 3px 0;
}
.fbp-summary-val { font-weight: 600; }
.fbp-summary-disc {
  border-top: 1px solid #1E2D45;
  padding-top: 8px;
  margin-top: 4px;
  font-size: 15px;
}
.fbp-bar-wrap {
  display: flex;
  height: 10px;
  border-radius: 5px;
  overflow: hidden;
  gap: 2px;
  margin-bottom: 6px;
}
.fbp-bar-seg { height: 100%; border-radius: 2px; }
.fbp-bar-legend { display: flex; gap: 12px; flex-wrap: wrap; }
.fbp-legend-item { display: flex; align-items: center; gap: 4px; font-size: 11px; color: #64748B; }
.fbp-legend-dot  { width: 7px; height: 7px; border-radius: 50%; }

/* ═══════════════════════════════════════════════════════════════════════
   ACCOUNT CARD — GOAL PROJECTION
   ═══════════════════════════════════════════════════════════════════════ */
.goal-projection {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 4px;
  flex-wrap: wrap;
}
.goal-badge {
  display: inline-block;
  border-radius: 8px;
  padding: 2px 8px;
  font-size: 11px;
  font-weight: 600;
  background: rgba(212,175,55,0.12);
  color: #D4AF37;
}
.goal-reached   { background: rgba(74,222,128,0.15); color: #4ADE80; font-size: 13px; }
.goal-no-contrib{ background: rgba(100,116,139,0.12); color: #64748B; }
.goal-proj-date { font-size: 11px; color: #475569; }

/* ═══════════════════════════════════════════════════════════════════════
   SYNC STATUS BAR
   ═══════════════════════════════════════════════════════════════════════ */
.sync-bar {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 11px;
  padding: 2px 6px;
  border-radius: 4px;
  white-space: nowrap;
}
.sync-bar.sync-ok    { color: #4ADE80; }
.sync-bar.sync-saving{ color: #FBBF24; }
.sync-bar.sync-error { color: #F87171; background: rgba(248,113,113,0.08); border: 1px solid rgba(248,113,113,0.3); }
.sync-key { opacity: 0.65; margin-left: 4px; }

.sync-dot {
  width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0;
}
.sync-dot-ok   { background: #4ADE80; }
.sync-dot-err  { background: #F87171; }
.sync-dot-pulse {
  background: #FBBF24;
  animation: syncPulse 0.8s ease-in-out infinite;
}
@keyframes syncPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%       { opacity: 0.4; transform: scale(0.7); }
}

/* ═══════════════════════════════════════════════════════════════════════
   BUDGET PLAN — HOUSEHOLD 3-COLUMN TABLE
   ═══════════════════════════════════════════════════════════════════════ */
.fbp-household-table {
  width: 100%;
  border-collapse: collapse;
}
.fbp-household-head,
.fbp-household-row {
  display: grid;
  grid-template-columns: 1.2fr 1fr 1fr 1fr;
  gap: 8px;
  padding: 8px 14px;
  border-bottom: 1px solid #0F1A2E;
  font-size: 13px;
  align-items: center;
}
.fbp-household-head {
  font-size: 11px;
  font-weight: 700;
  color: #475569;
  padding-bottom: 6px;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}
.fbp-household-row:last-child { border-bottom: none; }
.fbp-household-row > span:not(:first-child) {
  text-align: right;
  font-variant-numeric: tabular-nums;
}

/* ═══════════════════════════════════════════════════════════════════════
   BUDGET PLAN — EMPTY STATE & PAYDAY FORMAT
   ═══════════════════════════════════════════════════════════════════════ */
.fbp-empty-row {
  padding: 16px 14px;
  color: #475569;
  font-size: 13px;
  font-style: italic;
}
.fbp-payday .ie-value {
  color: #60A5FA;
  font-size: 12px;
}

/* ═══════════════════════════════════════════════════════════════════════
   BUDGET PLAN — VARIABLE BUDGET ROW
   ═══════════════════════════════════════════════════════════════════════ */
.fbp-varbudget-row {
  display: grid;
  grid-template-columns: 1fr auto 28px;
  align-items: center;
  gap: 8px;
  padding: 7px 14px;
  border-bottom: 1px solid #1E293B;
  font-size: 13px;
}
.fbp-varbudget-row:last-child { border-bottom: none; }
.fbp-varbudget-row > span { color: #CBD5E1; }

/* ═══════════════════════════════════════════════════════════════════════
   BUDGET PLAN — ADD SAVINGS MODAL
   ═══════════════════════════════════════════════════════════════════════ */
.fbp-modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.fbp-modal {
  background: #1E293B;
  border: 1px solid #334155;
  border-radius: 12px;
  padding: 24px;
  min-width: 340px;
  max-width: 420px;
  width: 100%;
  box-shadow: 0 20px 60px rgba(0,0,0,0.6);
}
.fbp-modal-title {
  font-size: 16px;
  font-weight: 700;
  color: #F8FAFC;
  margin-bottom: 18px;
}
.fbp-modal-field {
  display: flex;
  flex-direction: column;
  gap: 4px;
  margin-bottom: 14px;
}
.fbp-modal-field label {
  font-size: 11px;
  font-weight: 600;
  color: #94A3B8;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}
.fbp-modal-input,
.fbp-modal-select {
  background: #0F172A;
  border: 1px solid #334155;
  border-radius: 6px;
  color: #F8FAFC;
  font-size: 13px;
  padding: 8px 10px;
  outline: none;
  width: 100%;
  box-sizing: border-box;
}
.fbp-modal-input:focus,
.fbp-modal-select:focus {
  border-color: #60A5FA;
}
.fbp-modal-select option {
  background: #1E293B;
}
.fbp-modal-actions {
  display: flex;
  gap: 8px;
  justify-content: flex-end;
  margin-top: 20px;
}
.fbp-modal-actions button {
  padding: 8px 18px;
  border-radius: 6px;
  border: none;
  cursor: pointer;
  font-size: 13px;
  font-weight: 600;
}
.fbp-modal-actions button:first-child {
  background: #334155;
  color: #94A3B8;
}
.fbp-modal-actions button:first-child:hover {
  background: #475569;
  color: #F8FAFC;
}
.fbp-modal-actions button:last-child {
  background: #3B82F6;
  color: #fff;
}
.fbp-modal-actions button:last-child:hover {
  background: #2563EB;
}

/* ═══════════════════════════════════════════════════════════════════════
   PAYCHECK PANEL
   ═══════════════════════════════════════════════════════════════════════ */
.pc-panel {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 4px 40px;
}
.pc-panel-header { padding: 20px 4px 8px; }
.pc-panel-title {
  font-size: 22px;
  font-weight: 800;
  color: #F8FAFC;
  letter-spacing: -0.02em;
}
.pc-panel-sub { font-size: 13px; color: #64748B; margin-top: 2px; }

.pc-person-toggle { display: flex; gap: 8px; margin: 12px 0 16px; }
.pc-person-btn {
  padding: 8px 22px;
  border-radius: 8px;
  border: 1px solid #334155;
  background: #1E293B;
  color: #94A3B8;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.15s;
}
.pc-person-btn:hover { background: #253047; color: #F8FAFC; }
.pc-person-btn.active { background: #D4AF37; border-color: #D4AF37; color: #0A0F1E; }

.pc-view { display: flex; flex-direction: column; gap: 12px; }

.pc-motivation {
  display: flex;
  align-items: center;
  gap: 10px;
  background: linear-gradient(135deg, #1A1500 0%, #1E293B 100%);
  border: 1px solid #3D3300;
  border-radius: 10px;
  padding: 12px 16px;
}
.pc-motivation-icon { font-size: 18px; flex-shrink: 0; }
.pc-motivation-text { font-style: italic; color: #D4AF37; font-size: 13px; line-height: 1.5; }

.pc-header-card {
  background: #1E293B;
  border: 1px solid #334155;
  border-radius: 12px;
  padding: 16px 20px;
}
.pc-header-row { display: flex; flex-wrap: wrap; gap: 20px 32px; }
.pc-header-field { display: flex; flex-direction: column; gap: 4px; }
.pc-header-label {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: #475569;
}
.pc-header-value { font-size: 16px; font-weight: 700; color: #F8FAFC; }
.pc-header-value.gold  { color: #D4AF37; }
.pc-header-value.blue  { color: #60A5FA; }
.pc-header-value.muted { color: #64748B; font-weight: 500; font-size: 14px; }

.pc-alerts { display: flex; flex-direction: column; gap: 6px; }
.pc-alert {
  display: flex;
  align-items: center;
  gap: 10px;
  background: #1E293B;
  border: 1px solid #334155;
  border-left: 3px solid;
  border-radius: 8px;
  padding: 10px 14px;
  font-size: 13px;
}
.pc-alert-icon { font-size: 16px; flex-shrink: 0; }

.pc-label-section {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #475569;
  padding: 4px 2px;
}

.pc-step-card {
  background: #1E293B;
  border: 1px solid #334155;
  border-left: 3px solid;
  border-radius: 10px;
  overflow: hidden;
}
.pc-step-header {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 16px 10px;
  border-bottom: 1px solid #253047;
}
.pc-step-num {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 800;
  color: #0A0F1E;
  flex-shrink: 0;
}
.pc-step-icon  { font-size: 16px; }
.pc-step-title { font-size: 14px; font-weight: 700; color: #F8FAFC; }
.pc-step-body  { padding: 6px 0; }
.pc-step-subtotal {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 16px;
  border-top: 1px solid #253047;
  font-size: 12px;
  font-weight: 600;
  color: #94A3B8;
}
.pc-running-balance {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 16px 12px;
  font-size: 13px;
  background: #16213A;
}
.pc-rb-label  { color: #64748B; font-size: 12px; }
.pc-rb-amount { font-size: 15px; font-weight: 700; }
.pc-empty-msg { padding: 12px 16px; color: #475569; font-size: 13px; font-style: italic; }

.pc-bill-row {
  display: grid;
  grid-template-columns: 52px 1fr auto auto;
  align-items: center;
  gap: 8px;
  padding: 7px 16px;
  border-bottom: 1px solid #1A2235;
  font-size: 13px;
}
.pc-bill-row:last-of-type { border-bottom: none; }
.pc-bill-tag {
  font-size: 9px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  padding: 2px 5px;
  border-radius: 4px;
  text-align: center;
}
.pc-bill-tag.fixed    { background: #1E1020; color: #F87171; }
.pc-bill-tag.variable { background: #1A1800; color: #FBBF24; }
.pc-bill-tag.onetime  { background: #0F1E2A; color: #60A5FA; }
.pc-bill-tag.prepaid  { background: #0F1A14; color: #4ADE80; }
.pc-bill-name   { color: #CBD5E1; }
.pc-bill-due    { color: #64748B; font-size: 11px; }
.pc-bill-amount { font-weight: 600; color: #F87171; font-variant-numeric: tabular-nums; }

.pc-savings-row {
  display: grid;
  grid-template-columns: 10px 1fr auto auto;
  align-items: center;
  gap: 10px;
  padding: 8px 16px;
  border-bottom: 1px solid #1A2235;
  font-size: 13px;
}
.pc-savings-row:last-of-type { border-bottom: none; }
.pc-savings-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.pc-savings-name { color: #CBD5E1; }
.pc-roth-warn {
  display: inline-block;
  margin-left: 8px;
  font-size: 10px;
  color: #D4AF37;
  background: #1A1400;
  border: 1px solid #3D3300;
  border-radius: 4px;
  padding: 1px 5px;
}
.pc-savings-per-check { font-weight: 700; font-variant-numeric: tabular-nums; }
.pc-savings-per-month { font-size: 11px; color: #475569; }
.pc-savings-edit-note { padding: 8px 16px 10px; font-size: 11px; color: #475569; font-style: italic; }

.pc-var-row {
  display: grid;
  grid-template-columns: 1fr auto auto;
  align-items: center;
  gap: 10px;
  padding: 7px 16px;
  border-bottom: 1px solid #1A2235;
  font-size: 13px;
}
.pc-var-row:last-of-type { border-bottom: none; }
.pc-var-name   { color: #CBD5E1; }
.pc-var-note   { font-size: 11px; color: #475569; }
.pc-var-amount { font-weight: 600; color: #FBBF24; font-variant-numeric: tabular-nums; }

.pc-disc-card {
  background: #1E293B;
  border: 1px solid #334155;
  border-left: 3px solid;
  border-radius: 10px;
}
.pc-disc-body  { padding: 20px 20px 18px; text-align: center; }
.pc-disc-amount {
  font-size: 40px;
  font-weight: 900;
  letter-spacing: -0.03em;
  line-height: 1.1;
}
.pc-disc-pct  { font-size: 13px; color: #64748B; margin-top: 4px; }
.pc-disc-sub  { font-size: 12px; color: #475569; margin-top: 6px; font-style: italic; }
.pc-disc-warn {
  font-size: 12px;
  color: #F87171;
  margin-top: 8px;
  background: #1A0A0A;
  border-radius: 6px;
  padding: 6px 12px;
}

.pc-alloc-bar-wrap {
  background: #1E293B;
  border: 1px solid #334155;
  border-radius: 10px;
  padding: 14px 16px 12px;
}
.pc-alloc-bar-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #475569;
  margin-bottom: 10px;
}
.pc-alloc-bar {
  display: flex;
  height: 18px;
  border-radius: 9px;
  overflow: hidden;
  background: #0F172A;
  gap: 1px;
}
.pc-alloc-seg { height: 100%; transition: width 0.4s ease; min-width: 2px; }
.pc-alloc-bar-legend { display: flex; flex-wrap: wrap; gap: 8px 16px; margin-top: 10px; }
.pc-alloc-legend-item {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 12px;
  color: #94A3B8;
}
.pc-alloc-dot  { width: 8px; height: 8px; border-radius: 50%; }
.pc-alloc-lname { color: #64748B; }

.pc-bottom-row {
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: 12px;
  align-items: start;
}
@media (max-width: 700px) { .pc-bottom-row { grid-template-columns: 1fr; } }

.pc-pie-wrap {
  background: #1E293B;
  border: 1px solid #334155;
  border-radius: 10px;
  padding: 14px 16px 12px;
}
.pc-pie-legend { display: flex; flex-direction: column; gap: 5px; margin-top: 8px; }
.pc-pie-item {
  display: grid;
  grid-template-columns: 10px 1fr auto;
  align-items: center;
  gap: 7px;
  font-size: 12px;
}
.pc-pie-dot  { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.pc-pie-name { color: #94A3B8; }
.pc-pie-val  { font-variant-numeric: tabular-nums; font-weight: 600; }

.pc-monthly-wrap {
  background: #1E293B;
  border: 1px solid #334155;
  border-radius: 10px;
  padding: 14px 16px 12px;
}
.pc-monthly-table { display: flex; flex-direction: column; margin-top: 4px; }
.pc-monthly-head,
.pc-monthly-row {
  display: grid;
  grid-template-columns: 1fr repeat(4, auto);
  gap: 10px;
  padding: 7px 6px;
  font-size: 12px;
  align-items: center;
}
.pc-monthly-head {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  color: #475569;
  border-bottom: 1px solid #334155;
  padding-bottom: 6px;
}
.pc-monthly-row { border-bottom: 1px solid #1A2235; color: #CBD5E1; font-variant-numeric: tabular-nums; }
.pc-monthly-row:last-child { border-bottom: none; }
.pc-monthly-total { border-top: 1px solid #334155; font-weight: 700; color: #F8FAFC; border-bottom: none !important; }
.pc-monthly-head span:not(:first-child),
.pc-monthly-row  span:not(:first-child) { text-align: right; }
.pc-col-red    { color: #F87171; }
.pc-col-green  { color: #4ADE80; }
.pc-col-yellow { color: #FBBF24; }
.pc-monthly-note {
  font-size: 11px;
  color: #475569;
  margin-top: 10px;
  padding-top: 8px;
  border-top: 1px solid #253047;
  font-style: italic;
}

/* Jessica specifics */
.pc-job-toggle { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 4px; }
.pc-job-btn {
  padding: 7px 16px;
  border-radius: 8px;
  border: 1px solid #334155;
  background: #1E293B;
  color: #94A3B8;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.15s;
}
.pc-job-btn:hover { background: #253047; color: #F8FAFC; }
.pc-job-btn.active { background: #F472B6; border-color: #F472B6; color: #1E0020; }

.pc-jessica-input-wrap {
  display: flex;
  align-items: center;
  gap: 4px;
  background: #0F172A;
  border: 1px solid #334155;
  border-radius: 8px;
  padding: 0 10px;
  width: 160px;
}
.pc-jessica-input-wrap:focus-within { border-color: #60A5FA; }
.pc-dollar { color: #64748B; font-size: 14px; }
.pc-jessica-input {
  background: none;
  border: none;
  outline: none;
  color: #F8FAFC;
  font-size: 16px;
  font-weight: 700;
  width: 100%;
  padding: 7px 0;
}
.pc-jessica-input::placeholder { color: #334155; }
.pc-jessica-clear {
  background: none;
  border: none;
  color: #475569;
  cursor: pointer;
  font-size: 16px;
  padding: 0 2px;
  line-height: 1;
}
.pc-jessica-clear:hover { color: #F87171; }
.pc-jessica-using { margin-top: 10px; font-size: 12px; color: #64748B; }
.pc-jessica-using strong { color: #F8FAFC; }
.pc-jessica-estimated { color: #475569; }

.pc-jessica-alloc-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #1E293B;
  border: 1px solid #334155;
  border-left: 3px solid;
  border-radius: 10px;
  padding: 14px 16px;
  gap: 16px;
}
.pc-jessica-alloc-left { display: flex; flex-direction: column; gap: 3px; flex: 1; }
.pc-jessica-alloc-label { font-size: 14px; font-weight: 700; }
.pc-jessica-alloc-pct {
  font-size: 11px;
  color: #64748B;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.pc-jessica-alloc-note  { font-size: 12px; color: #475569; }
.pc-jessica-alloc-amount {
  font-size: 22px;
  font-weight: 800;
  font-variant-numeric: tabular-nums;
  flex-shrink: 0;
}

.pc-jessica-tips {
  background: #1E293B;
  border: 1px solid #334155;
  border-radius: 10px;
  padding: 14px 16px;
}
.pc-tips-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-top: 8px;
}
.pc-tip-card {
  background: #0F172A;
  border: 1px solid #1E293B;
  border-radius: 8px;
  padding: 12px;
  display: flex;
  flex-direction: column;
  gap: 3px;
}
.pc-tip-icon  { font-size: 18px; }
.pc-tip-label { font-size: 12px; color: #94A3B8; font-weight: 600; }
.pc-tip-pct   { font-size: 11px; color: #475569; }
.pc-tip-val   { font-size: 15px; font-weight: 700; color: #F472B6; font-variant-numeric: tabular-nums; }

.pc-jessica-placeholder {
  background: #1E293B;
  border: 1px dashed #334155;
  border-radius: 12px;
  padding: 40px 20px;
  text-align: center;
  color: #475569;
  font-size: 14px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
}
.pc-placeholder-icon { font-size: 40px; }
.pc-placeholder-sub  { font-size: 12px; color: #334155; }
