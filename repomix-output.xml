.rdr-tabs {
  display: flex;
  padding: 0 24px;
  border-bottom: 1px solid #1E2D45;
  flex-shrink: 0;
  background: #0D1526;
}
.rdr-tab {
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  padding: 12px 16px;
  font-size: 13px;
  color: #64748B;
