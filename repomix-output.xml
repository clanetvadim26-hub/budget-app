  background: #0A1020;
  flex-shrink: 0;
  overflow-x: auto;
}
.rdr-stat {
  display: flex;
  flex-direction: column;
  gap: 2px;
  min-width: 90px;
}
.rdr-stat-label {
  font-size: 11px;
  color: #64748B;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.rdr-stat-value {
  font-size: 18px;
  font-weight: 700;
  color: #D4AF37;
}
.rdr-stat-sub {
  font-size: 11px;
  color: #64748B;
}

.rdr-catch-up-toggle {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 24px;
  background: #0A1020;
  border-bottom: 1px solid #1E2D45;
  flex-shrink: 0;
}
