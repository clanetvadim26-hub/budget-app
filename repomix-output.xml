  overflow: hidden;
}

.alloc-bar-fill {
  height: 100%;
  border-radius: 5px;
  transition: width 0.5s ease;
}

.alloc-amount {
  width: 80px;
  text-align: right;
  font-size: 13px;
  font-weight: 700;
}

/* ========================
   UTILITIES
   ======================== */
.positive { color: #4ADE80; }
.negative { color: #F87171; }
.warning { color: #FACC15; }
