  gap: 12px;
}

.alloc-label {
  width: 180px;
  font-size: 13px;
  color: #CBD5E1;
  font-weight: 500;
  flex-shrink: 0;
}

.alloc-bar-wrap {
  flex: 1;
  height: 10px;
  background: #1E293B;
