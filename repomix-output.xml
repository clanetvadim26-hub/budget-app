.ph-amount { color: #4ADE80; font-weight: 600; font-family: monospace; }
.ph-person-badge { padding: 2px 8px; border-radius: 6px; font-size: 12px; font-weight: 600; }
.vadim-badge   { background: rgba(96,165,250,0.15);  color: #60A5FA; }
.jessica-badge { background: rgba(244,114,182,0.15); color: #F472B6; }
.ph-date { font-family: monospace; color: #94A3B8; }

/* ── Paycheck Sub-tab Toggle ─────────────────────────── */
.paycheck-tab-toggle { display: flex; background: #131d35; border-radius: 10px; padding: 4px; margin-bottom: 20px; width: fit-content; }
.tab-toggle-btn { background: transparent; border: none; color: #64748B; padding: 8px 20px; border-radius: 8px; font-size: 14px; font-weight: 500; cursor: pointer; transition: 0.15s; min-height: 36px; }
.tab-toggle-btn.active { background: #D4AF37; color: #0A0F1E; font-weight: 700; }

/* ── K401 Detail Panel ────────────────────────────────── */
.k401-panel { background: #131d35; border: 1px solid #1E293B; border-radius: 16px; padding: 20px; margin-bottom: 16px; }
.k401-title-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
.k401-icon { font-size: 28px; }
.k401-name { font-size: 16px; font-weight: 700; color: #F1F5F9; }
.k401-type { font-size: 12px; color: #64748B; margin-top: 2px; }
.k401-countdown { margin-left: auto; background: rgba(212,175,55,0.15); color: #D4AF37; border-radius: 8px; padding: 4px 12px; font-size: 12px; font-weight: 600; }
.k401-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 16px; margin-bottom: 20px; }
.k401-section { background: #0D1426; border: 1px solid #1E293B; border-radius: 12px; padding: 14px; display: flex; flex-direction: column; gap: 10px; }
.k401-section-title { font-size: 12px; font-weight: 600; color: #D4AF37; text-transform: uppercase; letter-spacing: 0.5px; }
.k401-field { display: flex; flex-direction: column; gap: 4px; }
.k401-field label { font-size: 11px; color: #64748B; }
.k401-input { background: #0A1020; border: 1px solid #1E293B; border-radius: 8px; color: #F1F5F9; font-size: 16px; padding: 8px 10px; width: 100%; box-sizing: border-box; }
.k401-input:focus { outline: none; border-color: #D4AF37; }
.k401-computed { font-size: 13px; color: #4ADE80; font-weight: 600; }
.k401-match-result { font-size: 13px; color: #60A5FA; background: rgba(96,165,250,0.1); border-radius: 8px; padding: 8px 10px; }
.k401-limit-bar { background: #0D1426; border: 1px solid #1E293B; border-radius: 12px; padding: 14px; }
.k401-limit-header { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; font-size: 13px; color: #CBD5E1; flex-wrap: wrap; }
.k401-limit-amount { font-weight: 700; color: #F1F5F9; margin-left: auto; }
.k401-catchup-badge { background: rgba(167,139,250,0.2); color: #A78BFA; border-radius: 6px; padding: 2px 8px; font-size: 11px; }
.k401-progress-fill { background: linear-gradient(90deg, #D4AF37, #4ADE80); }
.k401-limit-note { font-size: 12px; color: #64748B; margin-top: 6px; }

/* ── Accounts Panel additions ────────────────────────── */
.btn-rerun-setup { background: transparent; border: 1px solid #334155; color: #64748B; border-radius: 8px; padding: 8px 16px; font-size: 13px; cursor: pointer; margin-left: 8px; transition: 0.15s; }
.btn-rerun-setup:hover { border-color: #D4AF37; color: #D4AF37; }
.contrib-readonly { background: #0A1020; border: 1px solid #1E293B; border-radius: 8px; padding: 10px 12px; font-size: 14px; color: #D4AF37; display: flex; justify-content: space-between; align-items: center; }
.contrib-readonly-note { font-size: 11px; color: #64748B; }
.contrib-plan-note     { font-size: 11px; color: #64748B; }

/* ── Calendar Event Delete ───────────────────────────── */
.cal-event-delete { background: none; border: none; cursor: pointer; font-size: 14px; padding: 4px 6px; border-radius: 6px; opacity: 0.5; transition: 0.15s; flex-shrink: 0; }
.cal-event-delete:hover { opacity: 1; background: rgba(248,113,113,0.15); }
