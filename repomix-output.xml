  height: 6px;
  background: #1E293B;
  border-radius: 3px;
  overflow: hidden;
}

.pct-bar {
  display: block;
  height: 100%;
  background: #D4AF37;
  border-radius: 3px;
}

/* ========================
   CASH FLOW PANEL
   ======================== */
.cashflow-summary {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  margin-bottom: 24px;
}

.cf-stat {
  background: #131d35;
  border: 1px solid #1E293B;
  border-radius: 12px;
  padding: 16px 20px;
}

.cf-stat-label {
  font-size: 11px;
  font-weight: 600;
  color: #64748B;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 8px;
}

.cf-stat-value {
  font-size: 24px;
  font-weight: 700;
  letter-spacing: -0.5px;
}

.cashflow-table {
  margin-top: 24px;
  border: 1px solid #1E293B;
  border-radius: 12px;
  overflow: hidden;
}

.cashflow-table .table-header {
  grid-template-columns: repeat(4, 1fr);
}

.cashflow-table .table-row {
  grid-template-columns: repeat(4, 1fr);
}

.month-label {
  font-size: 13px;
  font-weight: 600;
  color: #94A3B8;
}

/* ========================
   SAVINGS TRACKER
   ======================== */
.savings-goals {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 20px;
}

.savings-goal-card {
  background: #131d35;
  border: 1px solid #1E293B;
  border-radius: 14px;
  padding: 20px;
}

.goal-header {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 14px;
}

.goal-icon { font-size: 22px; }

.goal-info { flex: 1; }

.goal-label {
  font-size: 15px;
  font-weight: 600;
  color: #F1F5F9;
}

.goal-desc {
  font-size: 12px;
  color: #64748B;
  margin-top: 2px;
}

.goal-pct {
  font-size: 20px;
  font-weight: 800;
}

.progress-bar-wrap {
  height: 8px;
  background: #1E293B;
  border-radius: 4px;
  overflow: hidden;
  margin-bottom: 10px;
}

.progress-bar-fill {
