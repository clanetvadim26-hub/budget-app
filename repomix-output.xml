  .day-num     { font-size: 11px; }
  .debt-overview-grid { grid-template-columns: 1fr; }
  .calc-form-grid { grid-template-columns: 1fr; }
}

/* ═══════════════════════════════════════════════════════════════
   CONNECTION STATUS INDICATOR
   ═══════════════════════════════════════════════════════════════ */

.conn-indicator {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-top: 6px;
}
.conn-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  display: inline-block;
  flex-shrink: 0;
}
.conn-pulse {
  animation: connPulse 1.4s ease-in-out infinite;
}
@keyframes connPulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.35; }
}
.conn-label {
  font-size: 10px;
  color: #64748B;
  letter-spacing: 0.3px;
}

/* ═══════════════════════════════════════════════════════════════
   INSTALLMENT LOANS
   ═══════════════════════════════════════════════════════════════ */

/* Add Loan Modal */
.add-loan-modal {
  background: #0F172A;
  border: 1px solid #1E293B;
  border-radius: 16px;
  padding: 28px;
  width: 680px;
  max-width: 95vw;
  max-height: 90vh;
  overflow-y: auto;
}
.loan-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24px;
}
.loan-modal-header h3 {
  color: #D4AF37;
  font-size: 18px;
  font-weight: 700;
  margin: 0;
}
.loan-form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px 20px;
}
.loan-span-2 { grid-column: span 2; }
.loan-term-group .term-input-row {
  display: flex;
  gap: 8px;
}
.loan-term-group .term-input-row input  { flex: 1; }
.loan-term-group .term-input-row select { width: 110px; }
.loan-form-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  margin-top: 20px;
  padding-top: 16px;
  border-top: 1px solid #1E293B;
}

/* Loans Section header */
.loans-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}
.loans-section-title {
  color: #CBD5E1;
  font-size: 16px;
  font-weight: 700;
  margin: 0;
}
.btn-add-loan {
  background: #D4AF37;
  color: #0A0F1E;
  border: none;
  border-radius: 8px;
  padding: 8px 16px;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  transition: opacity 0.15s;
}
.btn-add-loan:hover { opacity: 0.85; }

/* Loans list */
.loans-list { display: flex; flex-direction: column; gap: 16px; }

/* Loan Card */
.loan-card {
  background: #0F172A;
  border: 1px solid #1E293B;
  border-radius: 14px;
  padding: 20px;
  transition: border-color 0.2s;
}
.loan-card:hover { border-color: #334155; }

.loan-card-header { margin-bottom: 12px; }
.loan-card-title-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 6px;
}
.loan-type-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 11px;
  font-weight: 700;
  padding: 3px 10px;
  border-radius: 20px;
  border: 1px solid;
  letter-spacing: 0.3px;
}
.loan-owner-badge {
  font-size: 12px;
  font-weight: 600;
}
.loan-card-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.loan-card-name {
  font-size: 17px;
  font-weight: 700;
  color: #F1F5F9;
}
.loan-card-actions { display: flex; gap: 4px; }
.loan-action-btn {
  background: none;
  border: none;
  cursor: pointer;
  font-size: 15px;
  padding: 4px 6px;
  border-radius: 6px;
  transition: background 0.15s;
}
.loan-action-btn:hover { background: #1E293B; }

/* Balance row */
.loan-balance-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 14px;
}
.loan-balance-label { font-size: 11px; color: #64748B; margin-bottom: 2px; text-transform: uppercase; letter-spacing: 0.5px; }
.loan-balance-value { font-size: 22px; font-weight: 800; color: #F1F5F9; }
.loan-balance-value.negative { color: #F87171; }

/* Progress bar */
.loan-progress-wrap { margin-bottom: 16px; }
.loan-progress-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 6px;
}
.loan-progress-label { font-size: 12px; color: #94A3B8; }
.loan-progress-pct   { font-size: 12px; font-weight: 700; }
.loan-progress-track {
  height: 8px;
  background: #1E293B;
  border-radius: 4px;
  overflow: hidden;
  margin-bottom: 4px;
}
.loan-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #B8972A, #D4AF37);
  border-radius: 4px;
  transition: width 0.4s ease;
  min-width: 2px;
}
.loan-progress-sub { font-size: 11px; color: #64748B; }

/* Stats grid */
.loan-stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  margin-bottom: 12px;
}
.loan-stat-item {
  background: #0A0F1E;
  border: 1px solid #1E293B;
  border-radius: 8px;
  padding: 10px 12px;
  display: flex;
  flex-direction: column;
  gap: 3px;
}
.loan-stat-label { font-size: 10px; color: #64748B; text-transform: uppercase; letter-spacing: 0.4px; }
.loan-stat-val   { font-size: 14px; font-weight: 700; color: #F1F5F9; }

/* Notes */
.loan-notes {
  background: #0A0F1E;
  border: 1px solid #1E293B;
  border-radius: 8px;
  padding: 10px 12px;
  font-size: 12px;
  color: #94A3B8;
  margin-bottom: 12px;
  font-style: italic;
}

/* Expand button */
.loan-expand-btn {
  width: 100%;
  background: none;
  border: 1px solid #1E293B;
  border-radius: 8px;
  color: #D4AF37;
  font-size: 13px;
  font-weight: 600;
  padding: 10px;
  cursor: pointer;
  transition: background 0.15s, border-color 0.15s;
  margin-top: 4px;
}
.loan-expand-btn:hover { background: #1E293B; border-color: #334155; }

/* Amortization schedule */
.amort-wrap { margin-top: 20px; }
.amort-table-wrap {
  max-height: 540px;
  overflow-y: auto;
  border: 1px solid #1E293B;
  border-radius: 10px;
  margin-top: 16px;
}
.amort-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 12px;
}
.amort-table th {
  background: #0A0F1E;
  color: #64748B;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  padding: 10px 12px;
  text-align: right;
  position: sticky;
  top: 0;
  z-index: 2;
  border-bottom: 1px solid #1E293B;
}
.amort-table th:first-child,
.amort-table th:nth-child(2) { text-align: left; }
.amort-table td {
  padding: 8px 12px;
  text-align: right;
  color: #CBD5E1;
  border-bottom: 1px solid #0F172A;
}
.amort-table td:first-child,
.amort-table td:nth-child(2) { text-align: left; }
.amort-table tbody tr:nth-child(even) td { background: #0A0F1E55; }
.amort-table tbody tr:hover td { background: #1E293B55; }
.amort-table tbody tr.amort-current td {
  background: #D4AF3718;
  color: #F1F5F9;
  font-weight: 700;
}
.amort-next-badge {
  display: inline-block;
  background: #D4AF3733;
  color: #D4AF37;
  font-size: 9px;
  font-weight: 700;
  padding: 1px 6px;
  border-radius: 10px;
  margin-left: 6px;
  vertical-align: middle;
  letter-spacing: 0.4px;
}
.amort-table tfoot td {
  background: #0A0F1E;
  color: #94A3B8;
  font-weight: 700;
  font-size: 12px;
  border-top: 2px solid #1E293B;
  border-bottom: none;
}

/* Timeline legend hint */
.timeline-legend-hint {
  margin-bottom: 8px;
  min-height: 18px;
}

/* Day Modal loan row */
.dmg-row-loan { align-items: flex-start; gap: 8px; }
.dmg-loan-info { display: flex; flex-direction: column; gap: 2px; flex: 1; min-width: 0; }
.dmg-loan-breakdown { font-size: 11px; color: #64748B; }

/* Responsive */
@media (max-width: 768px) {
  .loan-stats-grid   { grid-template-columns: 1fr 1fr; }
  .loan-form-grid    { grid-template-columns: 1fr; }
  .loan-span-2       { grid-column: span 1; }
  .add-loan-modal    { padding: 16px; }
}
@media (max-width: 480px) {
  .loan-stats-grid   { grid-template-columns: 1fr; }
  .loan-balance-value { font-size: 18px; }
}

/* ═══════════════════════════════════════════════════════════════
   MOBILE — GLOBAL FIXES
   ═══════════════════════════════════════════════════════════════ */

/* Smooth scrolling everywhere */
html { scroll-behavior: smooth; }

/* Prevent double-tap zoom on interactive elements */
button, a, input, select, textarea {
  touch-action: manipulation;
}

/* Minimum tap target size (44px) for all buttons */
button {
  min-height: 44px;
  min-width: 44px;
}

/* Better text sizing on iOS */
input, select, textarea {
  font-size: 16px; /* prevents iOS auto-zoom on focus */
}

/* Safe-area insets for iPhone notch / home indicator */
.app {
  padding-bottom: env(safe-area-inset-bottom, 0);
}

/* ═══════════════════════════════════════════════════════════════
   MOBILE BOTTOM NAV
   ═══════════════════════════════════════════════════════════════ */

/* Hide the sidebar navbar on mobile */
@media (max-width: 768px) {
  .navbar {
    display: none !important;
  }
  .main-content {
    margin-left: 0 !important;
    padding-bottom: calc(72px + env(safe-area-inset-bottom, 0px));
  }
}

/* Bottom tab bar */
.mobile-nav {
  display: none; /* hidden on desktop */
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(60px + env(safe-area-inset-bottom, 0px));
  padding-bottom: env(safe-area-inset-bottom, 0px);
  background: #0A0F1E;
  border-top: 1px solid #1E293B;
  display: flex;
  align-items: center;
  justify-content: space-around;
  z-index: 1000;
  box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.4);
}

/* Show mobile nav only on small screens */
@media (min-width: 769px) {
  .mobile-nav { display: none !important; }
}
@media (max-width: 768px) {
  .mobile-nav { display: flex; }
}

.mobile-nav-tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 6px 4px;
  min-height: 60px;
  min-width: 44px;
  border-radius: 0;
  position: relative;
  transition: opacity 0.15s;
  -webkit-tap-highlight-color: transparent;
}
.mobile-nav-tab:hover { opacity: 0.85; }
.mobile-tab-icon {
  font-size: 20px;
  line-height: 1;
  position: relative;
}
.mobile-tab-label {
  font-size: 10px;
  color: #64748B;
  font-weight: 500;
  letter-spacing: 0.2px;
}
.mobile-nav-tab.active .mobile-tab-label { color: #D4AF37; }
.mobile-nav-tab.active .mobile-tab-icon  { filter: drop-shadow(0 0 4px #D4AF3780); }

/* The raised Add button */
.add-tab {
  flex: 0 0 56px;
  margin-bottom: 12px;
  background: #D4AF37;
  border-radius: 50%;
  width: 56px;
  height: 56px;
  min-width: 56px;
  min-height: 56px;
  padding: 0;
  box-shadow: 0 4px 16px rgba(212, 175, 55, 0.45);
}
.add-tab .mobile-tab-icon  { font-size: 22px; color: #0A0F1E; }
.add-tab .mobile-tab-label { display: none; }
.add-tab.active { background: #B8972A; }

/* Badge on overview tab */
.mobile-nav-badge {
  position: absolute;
  top: -4px;
  right: -8px;
  background: #F87171;
  color: #fff;
  font-size: 9px;
  font-weight: 800;
  min-width: 16px;
  height: 16px;
  border-radius: 8px;
  padding: 0 3px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Sheet backdrop */
.mobile-sheet-backdrop {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 998;
  -webkit-tap-highlight-color: transparent;
}

/* More sheet (bottom drawer) */
.mobile-more-sheet {
  position: fixed;
  bottom: calc(60px + env(safe-area-inset-bottom, 0px));
  left: 0;
  right: 0;
  background: #0F172A;
  border-top: 1px solid #1E293B;
  border-radius: 20px 20px 0 0;
  padding: 12px 16px 20px;
  z-index: 999;
  animation: slideUp 0.22s ease-out;
}
@keyframes slideUp {
  from { transform: translateY(100%); opacity: 0; }
  to   { transform: translateY(0);    opacity: 1; }
}
.mobile-sheet-handle {
  width: 36px;
  height: 4px;
  background: #334155;
  border-radius: 2px;
  margin: 0 auto 16px;
}
.mobile-more-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
}
.mobile-more-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5px;
  background: #0A0F1E;
  border: 1px solid #1E293B;
  border-radius: 12px;
  padding: 12px 4px;
  cursor: pointer;
  transition: border-color 0.15s, background 0.15s;
  min-height: 72px;
  -webkit-tap-highlight-color: transparent;
}
.mobile-more-item:hover,
.mobile-more-item.active { background: #1E293B; border-color: #D4AF37; }
.more-item-icon  { font-size: 22px; }
.more-item-label { font-size: 10px; color: #94A3B8; font-weight: 500; text-align: center; }
.mobile-more-item.active .more-item-label { color: #D4AF37; }

/* Add menu (above the Add button) */
.mobile-add-menu {
  position: fixed;
  bottom: calc(72px + env(safe-area-inset-bottom, 0px));
  left: 50%;
  transform: translateX(-50%);
  background: #0F172A;
  border: 1px solid #1E293B;
  border-radius: 14px;
  overflow: hidden;
  z-index: 999;
  min-width: 180px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.5);
  animation: slideUp 0.18s ease-out;
}
.add-menu-item {
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
  padding: 14px 18px;
  background: none;
  border: none;
  cursor: pointer;
  color: #F1F5F9;
  font-size: 14px;
  font-weight: 600;
  min-height: 48px;
  transition: background 0.15s;
  -webkit-tap-highlight-color: transparent;
}
.add-menu-item:first-child { border-bottom: 1px solid #1E293B; }
.add-menu-item:hover { background: #1E293B; }

/* ═══════════════════════════════════════════════════════════════
   PWA: INSTALL BANNER + UPDATE TOAST
   ═══════════════════════════════════════════════════════════════ */

/* Update toast (fixed top) */
.pwa-update-toast {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #D4AF37;
  color: #0A0F1E;
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 16px;
  padding-top: calc(10px + env(safe-area-inset-top, 0px));
  z-index: 9999;
  box-shadow: 0 2px 12px rgba(212, 175, 55, 0.4);
}
.pwa-update-text {
  flex: 1;
  font-size: 14px;
  font-weight: 600;
}
.pwa-update-btn {
  background: #0A0F1E;
  color: #D4AF37;
  border: none;
  border-radius: 8px;
  padding: 6px 14px;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  min-height: 36px;
  white-space: nowrap;
}

/* Install / iOS banner (fixed bottom, above mobile nav) */
.pwa-banner {
  position: fixed;
  bottom: calc(60px + env(safe-area-inset-bottom, 0px));
  left: 8px;
  right: 8px;
  background: #0F172A;
  border: 1px solid #D4AF3755;
  border-radius: 16px;
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 16px;
  z-index: 997;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6);
  animation: slideUp 0.25s ease-out;
}
/* On desktop, anchor to bottom of screen instead */
@media (min-width: 769px) {
  .pwa-banner {
    bottom: 20px;
    max-width: 420px;
    left: auto;
    right: 20px;
  }
}
.pwa-banner-icon img {
  border-radius: 10px;
}
.pwa-banner-text { flex: 1; min-width: 0; }
.pwa-banner-title {
  font-size: 14px;
  font-weight: 700;
  color: #F1F5F9;
  margin-bottom: 2px;
}
.pwa-banner-sub {
  font-size: 12px;
  color: #94A3B8;
  line-height: 1.4;
}
.pwa-banner-sub strong { color: #CBD5E1; }
.ios-share-icon {
  display: inline-block;
  background: #3B82F6;
  color: #fff;
  font-size: 11px;
  padding: 1px 5px;
  border-radius: 5px;
  font-style: normal;
  vertical-align: middle;
}
.pwa-install-btn {
  background: #D4AF37;
  color: #0A0F1E;
  border: none;
  border-radius: 10px;
  padding: 8px 16px;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  white-space: nowrap;
  min-height: 44px;
}
.pwa-dismiss-x {
  background: none;
  border: none;
  color: #64748B;
  font-size: 20px;
  line-height: 1;
  cursor: pointer;
  padding: 4px;
  min-height: 36px;
  min-width: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  flex-shrink: 0;
}
.pwa-dismiss-x:hover { background: #1E293B; color: #94A3B8; }

/* ========================
   ADD ACCOUNT FORM — DYNAMIC
   ======================== */
.add-account-panel {}
.add-account-section-label {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: #D4AF37;
  margin: 18px 0 10px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.color-picker-row {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
  margin-top: 4px;
}
.color-swatch {
  width: 26px;
  height: 26px;
  border-radius: 50%;
  border: 2px solid transparent;
  cursor: pointer;
  transition: transform 0.1s, border-color 0.15s;
}
.color-swatch:hover { transform: scale(1.2); }
.color-swatch.selected { border-color: #fff; transform: scale(1.2); box-shadow: 0 0 0 2px #D4AF37; }
.color-custom-input {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  border: 2px solid #1E2A45;
  cursor: pointer;
  padding: 0;
  background: none;
}
.connection-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
  flex-wrap: wrap;
}
.conn-account-select { flex: 2; min-width: 130px; }
.conn-flow-select    { flex: 1.5; min-width: 110px; }
.conn-amount-input   { flex: 1; min-width: 80px; }
.conn-label-input    { flex: 1.5; min-width: 100px; }

/* ========================
   MONEY FLOW MAP
   ======================== */
.flow-panel {
  display: flex;
  flex-direction: column;
  height: calc(100vh - 120px);
  min-height: 500px;
  background: #080D1A;
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid #1E2A45;
}
.flow-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 16px;
  background: #0A0F1E;
  border-bottom: 1px solid #1E2A45;
  flex-shrink: 0;
}
.flow-toolbar-left, .flow-toolbar-right { display: flex; align-items: center; gap: 8px; }
.flow-view-btn {
  padding: 5px 14px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 600;
  background: transparent;
  border: 1px solid #1E2A45;
  color: #64748B;
  cursor: pointer;
  transition: all 0.15s;
}
.flow-view-btn.active { background: #D4AF3722; border-color: #D4AF37; color: #D4AF37; }
.flow-zoom-btn {
  width: 30px; height: 30px;
  border-radius: 6px;
  background: #0F1629;
  border: 1px solid #1E2A45;
  color: #94A3B8;
  font-size: 16px;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
}
.flow-zoom-btn:hover { background: #1E2A45; color: #E2E8F0; }
.flow-zoom-label { font-size: 12px; color: #64748B; min-width: 36px; text-align: center; }
.flow-reset-btn {
  padding: 5px 12px;
  border-radius: 8px;
  background: transparent;
  border: 1px solid #1E2A45;
  color: #64748B;
  font-size: 12px;
  cursor: pointer;
}
.flow-reset-btn:hover { border-color: #60A5FA; color: #60A5FA; }
.flow-body {
  display: flex;
  flex: 1;
  overflow: hidden;
}
.flow-canvas-wrap {
  flex: 1;
  overflow: auto;
  position: relative;
}
.flow-svg {
  display: block;
}
/* Arrow animation */
@keyframes flowPulse {
  from { stroke-dashoffset: 20; }
  to   { stroke-dashoffset: 0; }
}
.flow-arrow-animated {
  animation: flowPulse 1.2s linear infinite;
}
/* Sidebar */
.flow-sidebar {
  width: 200px;
  flex-shrink: 0;
  background: #0A0F1E;
  border-left: 1px solid #1E2A45;
  padding: 16px;
  overflow-y: auto;
}
.flow-sidebar-title {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: #64748B;
  margin-bottom: 10px;
}
.flow-sidebar-stat {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}
.fss-label { font-size: 11px; color: #64748B; }
.fss-value { font-size: 12px; font-weight: 700; }
.fss-value.positive { color: #4ADE80; }
.fss-value.negative { color: #F87171; }
.flow-sidebar-divider { border-top: 1px solid #1E2A45; margin: 12px 0; }
.fss-hint { font-size: 11px; color: #475569; line-height: 1.5; margin-top: 8px; }
/* Legend */
.flow-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  padding: 8px 16px;
  border-top: 1px solid #1E2A45;
  background: #0A0F1E;
  flex-shrink: 0;
}
.flow-legend-item { display: flex; align-items: center; gap: 5px; font-size: 11px; color: #64748B; }
.flow-legend-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
/* List view */
.flow-list-view { flex: 1; overflow-y: auto; padding: 16px; }
.flow-list-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  background: #0F1629;
  border-radius: 10px;
  margin-bottom: 8px;
  flex-wrap: wrap;
  font-size: 13px;
}
.flow-from, .flow-to { color: #E2E8F0; font-weight: 600; }
.flow-arrow-label { font-size: 12px; font-weight: 700; }
.flow-amount { margin-left: auto; font-weight: 700; font-size: 13px; }

/* ========================
   REFINANCE SCENARIOS
   ======================== */
.refinance-section {
  margin-top: 24px;
  padding-top: 20px;
  border-top: 1px solid #1E2A45;
}
.refinance-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14px;
}
.refinance-title {
  font-size: 14px;
  font-weight: 700;
  color: #D4AF37;
}
.scenario-form {
  background: #080D1A;
  border: 1px solid #1E2A45;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
}
.scenario-auto-calc {
  font-size: 11px;
  color: #D4AF37;
  font-weight: 500;
  margin-left: 6px;
}
.scenario-cards {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 12px;
  margin-bottom: 20px;
}
.scenario-card {
  background: #080D1A;
  border: 1px solid #1E2A45;
  border-radius: 12px;
  padding: 14px;
}
.scenario-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}
.scenario-name { font-size: 13px; font-weight: 700; }
.scenario-card-actions { display: flex; align-items: center; gap: 6px; }
.scenario-best-badge {
  font-size: 9px;
  font-weight: 700;
  background: #D4AF3722;
  color: #D4AF37;
  border: 1px solid #D4AF3755;
  border-radius: 20px;
  padding: 2px 8px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.scenario-stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}
.scenario-stat {}
.ss-label { display: block; font-size: 10px; color: #64748B; margin-bottom: 2px; }
.ss-val { font-size: 12px; font-weight: 700; color: #E2E8F0; }
.ss-val.positive { color: #4ADE80; }
.ss-val.negative { color: #F87171; }
.scenario-notes {
  margin-top: 8px;
  font-size: 11px;
  color: #64748B;
  font-style: italic;
}
.refinance-chart-title {
  font-size: 12px;
  font-weight: 700;
  color: #94A3B8;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 10px;
}
.scenario-compare-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 12px;
  margin-top: 16px;
}
.scenario-compare-table th {
  text-align: left;
  color: #64748B;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  padding: 6px 10px;
  border-bottom: 1px solid #1E2A45;
}
.scenario-compare-table td {
  padding: 8px 10px;
  color: #CBD5E1;
  border-bottom: 1px solid #0F1629;
}
.scenario-compare-table tr:hover td { background: #0A0F1E; }
.scenario-compare-current td { color: #94A3B8; font-style: italic; }
.scenario-compare-table .positive { color: #4ADE80; }
.scenario-compare-table .negative { color: #F87171; }

/* ═══════════════════════════════════════════════════════════════════════
   RETIREMENT DETAIL DRAWER
   ═══════════════════════════════════════════════════════════════════════ */
.rdr-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.65);
  z-index: 500;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}
.rdr-drawer {
  background: #0D1526;
  border-radius: 18px 18px 0 0;
  width: 100%;
  max-width: 720px;
  max-height: 90vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -8px 40px rgba(0,0,0,0.7);
  animation: rdr-slide-up 0.3s ease;
}
@keyframes rdr-slide-up {
  from { transform: translateY(100%); opacity: 0; }
  to   { transform: translateY(0);    opacity: 1; }
}
.rdr-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 24px 16px;
  border-bottom: 1px solid #1E2D45;
  flex-shrink: 0;
}
.rdr-header h3 {
  margin: 0;
  font-size: 18px;
  font-weight: 700;
  color: #F1F5F9;
}
.rdr-header-sub {
  font-size: 13px;
  color: #64748B;
  margin-top: 2px;
}
.rdr-close-btn {
  background: #1E2D45;
  border: none;
  color: #94A3B8;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  font-size: 18px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s;
}
.rdr-close-btn:hover { background: #2D3F5E; color: #F1F5F9; }

.rdr-stats-bar {
  display: flex;
  gap: 12px;
  padding: 16px 24px;
  background: #0A1020;
  flex-shrink: 0;
  overflow-x: auto;
}
.rdr-stat {
  display: flex;
  flex-direction: column;
  gap: 2px;
  min-width: 90px;
}
.rdr-stat-label {
  font-size: 11px;
  color: #64748B;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.rdr-stat-value {
  font-size: 18px;
  font-weight: 700;
  color: #D4AF37;
}
.rdr-stat-sub {
  font-size: 11px;
  color: #64748B;
}

.rdr-catch-up-toggle {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 24px;
  background: #0A1020;
  border-bottom: 1px solid #1E2D45;
  flex-shrink: 0;
}
.rdr-catch-up-toggle label {
  font-size: 13px;
  color: #94A3B8;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 6px;
}
.rdr-catch-up-toggle input[type="checkbox"] { accent-color: #D4AF37; }
.rdr-catchup-note { font-size: 11px; color: #64748B; margin-left: 4px; }

.rdr-tabs {
  display: flex;
  padding: 0 24px;
  border-bottom: 1px solid #1E2D45;
  flex-shrink: 0;
  background: #0D1526;
}
.rdr-tab {
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  padding: 12px 16px;
  font-size: 13px;
  color: #64748B;
  cursor: pointer;
  transition: color 0.2s, border-color 0.2s;
  white-space: nowrap;
}
.rdr-tab:hover { color: #CBD5E1; }
.rdr-tab.active { color: #D4AF37; border-bottom-color: #D4AF37; }

.rdr-body {
  flex: 1;
  overflow-y: auto;
  padding: 20px 24px 32px;
}

/* History tab */
.rdr-history {}
.rdr-year-table { width: 100%; border-collapse: collapse; }
.rdr-year-row td {
  padding: 10px 8px;
  border-bottom: 1px solid #1E2D45;
  font-size: 13px;
  color: #CBD5E1;
}
.rdr-year-row:hover td { background: #0A1020; cursor: pointer; }
.rdr-year-toggle { color: #64748B; font-size: 11px; }
.rdr-year-table th {
  font-size: 11px;
  color: #64748B;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  padding: 8px 8px;
  text-align: left;
  border-bottom: 1px solid #1E2D45;
}
.rdr-mini-progress {
  height: 6px;
  background: #1E2D45;
  border-radius: 3px;
  overflow: hidden;
  width: 80px;
  display: inline-block;
  vertical-align: middle;
}
.rdr-mini-fill {
  height: 100%;
  border-radius: 3px;
  transition: width 0.4s ease;
}
.rdr-status-badge {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 10px;
  font-size: 11px;
  font-weight: 600;
  background: #1E2D45;
}
.rdr-entry-section {
  padding: 8px 8px 8px 24px;
  background: #08101E;
  border-bottom: 1px solid #1E2D45;
}
.rdr-entry-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6px 0;
  border-bottom: 1px solid #1A2540;
  font-size: 12px;
  color: #94A3B8;
}
.rdr-entry-row:last-child { border-bottom: none; }
.rdr-entry-del {
  background: none;
  border: none;
  color: #F87171;
  cursor: pointer;
  font-size: 14px;
  padding: 2px 6px;
  border-radius: 4px;
}
.rdr-entry-del:hover { background: rgba(248,113,113,0.1); }
.rdr-no-entries { font-size: 12px; color: #475569; padding: 6px 0; }

/* Charts tab */
.rdr-charts {}
.rdr-chart-title {
  font-size: 13px;
  font-weight: 600;
  color: #94A3B8;
  margin: 0 0 8px;
}
.rdr-chart-section { margin-bottom: 28px; }

/* Add Contribution tab */
.rdr-contrib-form { display: flex; flex-direction: column; gap: 14px; }
.rdr-contrib-form label {
  font-size: 12px;
  color: #94A3B8;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.rdr-contrib-form input, .rdr-contrib-form textarea, .rdr-contrib-form select {
  background: #0A1020;
  border: 1px solid #1E2D45;
  color: #F1F5F9;
  border-radius: 6px;
  padding: 8px 10px;
  font-size: 13px;
}
.rdr-contrib-form input:focus, .rdr-contrib-form textarea:focus, .rdr-contrib-form select:focus {
  outline: none;
  border-color: #D4AF37;
}
.rdr-contrib-submit {
  background: #D4AF37;
  color: #0A0F1E;
  border: none;
  border-radius: 8px;
  padding: 10px 20px;
  font-size: 14px;
  font-weight: 700;
  cursor: pointer;
  align-self: flex-start;
  transition: opacity 0.2s;
}
.rdr-contrib-submit:hover { opacity: 0.85; }
.rdr-warning-banner {
  background: rgba(251,191,36,0.1);
  border: 1px solid #FBBF24;
  border-radius: 8px;
  padding: 10px 14px;
  font-size: 12px;
  color: #FBBF24;
  margin-bottom: 12px;
}
.rdr-room-left {
  font-size: 12px;
  color: #4ADE80;
  margin-bottom: 8px;
}
.rdr-nontira-stats { display: flex; flex-direction: column; gap: 12px; }

/* ═══════════════════════════════════════════════════════════════════════
   INVESTMENTS PANEL — YEAR SELECTOR & ROTH BARS
   ═══════════════════════════════════════════════════════════════════════ */
.year-selector {
  display: flex;
  gap: 6px;
  margin-bottom: 16px;
  flex-wrap: wrap;
}
.year-btn {
  background: #1E2D45;
  border: 1px solid #2D3F5E;
  color: #94A3B8;
