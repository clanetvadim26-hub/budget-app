            <div style={s.secTitle}>Year-by-Year Summary</div>
            <div style={{ overflowX: 'auto' }}>
              <table style={s.table}>
                <thead>
                  <tr>
                    {['Year', 'Principal Paid', 'Interest Paid', 'Balance', 'Equity %'].map(h => <th key={h} style={s.th}>{h}</th>)}
                  </tr>
