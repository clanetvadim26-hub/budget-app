  margin: 0;
  font-size: 18px;
  font-weight: 700;
  color: #F1F5F9;
}
.rdr-header-sub {
  font-size: 13px;
  color: #64748B;
  margin-top: 2px;
}
.rdr-close-btn {
  background: #1E2D45;
  border: none;
  color: #94A3B8;
  width: 32px;
  height: 32px;
  border-radius: 50%;
