}
.pc-tips-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-top: 8px;
}
.pc-tip-card {
  background: #0F172A;
  border: 1px solid #1E293B;
  border-radius: 8px;
  padding: 12px;
