}

.roth-combined-bar {
  background: #0A1020;
  border: 1px solid #2D3F5E;
  border-radius: 10px;
  padding: 14px 16px;
  margin-top: 4px;
}
.roth-combined-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}
.roth-combined-label {
  font-size: 13px;
  font-weight: 600;
  color: #94A3B8;
}
.roth-combined-sub {
  font-size: 12px;
  color: #64748B;
  margin-top: 6px;
}

.roth-deadline-banner {
  border-radius: 8px;
  padding: 10px 14px;
  font-size: 13px;
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.roth-deadline-banner.warning {
  background: rgba(251,191,36,0.1);
  border: 1px solid #FBBF24;
  color: #FBBF24;
}
.roth-deadline-banner.error {
  background: rgba(248,113,113,0.1);
